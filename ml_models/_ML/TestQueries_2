LEFT JOIN coach_schedule cs ON cp."Id" = cs."CoachId"
WHERE cp."Id" = 1 -- Replace with parameter
  AND cp."HourlyRate" BETWEEN 0 AND 1000 -- Replace with @MinHourlyRate and @MaxHourlyRate
  AND coach_u."IsActive" = true
